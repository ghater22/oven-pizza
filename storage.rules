rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isAuthorized() {
      return signedIn() && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isOwner() {
      return isAuthorized() && userDoc().data.role == 'owner';
    }

    function canAccessBranch(branchId) {
      return isOwner() || branchId in userDoc().data.branchIds;
    }

    match /receipts/{branchId}/{recordType}/{fileName} {
      allow read: if isAuthorized() && canAccessBranch(branchId);
      allow write: if isAuthorized()
        && canAccessBranch(branchId)
        && recordType in ['revenues', 'expenses']
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}

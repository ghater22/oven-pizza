rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthorized() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isOwner() {
      return isAuthorized() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    function isAccountant() {
      return isAuthorized() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'accountant';
    }

    function isInputRole() {
      return isOwner() || isAccountant();
    }

    function canAccessBranch(branchId) {
      return isOwner() ||
        (isAccountant() &&
          branchId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchIds);
    }

    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isOwner());
      allow create: if isOwner();
      allow update, delete: if isOwner() && request.auth.uid != uid;
    }

    match /branches/{branchId} {
      allow read: if isAuthorized();
      allow write: if isOwner();

      match /revenues/{revenueId} {
        allow read, update, delete: if isOwner();
        allow create: if isInputRole() && canAccessBranch(branchId);
      }

      match /expenses/{expenseId} {
        allow read, update, delete: if isOwner();
        allow create: if isInputRole() && canAccessBranch(branchId);
      }
    }

    match /products/{productId} {
      allow read: if isAuthorized();
      allow write: if isOwner();
    }

    match /operationLogs/{logId} {
      allow read: if isOwner();
      allow create: if isAuthorized();
      allow update, delete: if false;
    }
  }
}
